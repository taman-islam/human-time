{
  "name": "@taman-islam/human-time",
  "version": "0.1.0",
  "type": "module",
  "description": "Zero-dependency relative time formatter for UI systems. Built on native Intl.PluralRules.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jhotika/human-time.git"
  },
  "homepage": "https://github.com/jhotika/human-time#readme",
  "bugs": {
    "url": "https://github.com/jhotika/human-time/issues"
  },
  "keywords": [
    "time",
    "datetime",
    "relative-time",
    "intl",
    "pluralrules",
    "ui",
    "formatter"
  ],
  "author": "Taman Islam",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint": "^9.17.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest": "^29.7.0",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5",
    "@stylistic/eslint-plugin": "^2.12.1"
  }
}
